{
  "version": 2,
  "installCommand": "npm --prefix \"farm-certification/farm-certification/farmer\" install",
  "buildCommand": "npm --prefix \"farm-certification/farm-certification/farmer\" run build",
  "outputDirectory": "farm-certification/farm-certification/farmer/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "http://localhost:3000/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
