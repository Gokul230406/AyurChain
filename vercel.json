{
  "version": 2,
  "installCommand": "npm --prefix \"farm-certification/farm-certification/farmer\" install && npm --prefix \"farm-certification/farm-certification/backend\" install",
  "buildCommand": "npm --prefix \"farm-certification/farm-certification/farmer\" run build",
  "outputDirectory": "farm-certification/farm-certification/farmer/dist",
  "functions": {
    "api/index.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
